digraph WlanTimerCamera {
    graph [
        rankdir=LR
        fontname="Arial"
        fontsize=11
        label="WLAN Timer Camera — Schaltplan\nTPL5110 Power-Timer · AO3400 N-Kanal Low-Side-Switch · ESP32-CAM"
        labelloc=t
        labeljust=c
        splines=spline
        nodesep=0.45
        ranksep=1.3
        compound=true
        bgcolor=white
        pad=0.3
        size="11.5,7.8"
        ratio=compress
    ]
    node [fontname="Arial" fontsize=9 style="filled,rounded" shape=box margin="0.12,0.08"]
    edge [
        fontname="Arial"
        fontsize=8
        penwidth=1.4
        labelfontsize=8
        labeldistance=2.0
        labelangle=25
    ]

    // ── GND-Symbol (nur intern in Vorschaltplatine) ───────────────────────────
    node [shape=invtriangle style=filled fillcolor="#444444" fontcolor=white
          fontsize=8 width=0.4 height=0.28 margin="0.04,0.04" label="GND"]
    gnd_vorschalt

    // Normalen Node-Stil wiederherstellen
    node [shape=box style="filled,rounded" fontsize=10 fontcolor=black
          margin="0.2,0.12" width=1.0 height=0.6 label=""]


    // ── Cluster: Stromversorgung ──────────────────────────────────────────────
    //    Außenanschluss: 2 Ausgangspins (3,3V und GND)
    subgraph cluster_psu {
        label="Stromversorgung"
        style=filled fillcolor="#FFF8E1" color="#E65100" penwidth=2
        fontname="Arial" fontsize=11

        // ── 2 Ausgangspins ────────────────────────────────────────────────────
        node [shape=box style="filled" fillcolor="#ECEFF1" color="#546E7A"
              penwidth=1.6 fontsize=8 fontname="Courier New"
              width=0.62 height=0.32 margin="0.05,0.04"]
        psu_3V3 [label="3,3 V"]
        psu_GND [label="GND"]

        // ── Interne Bauteile ──────────────────────────────────────────────────
        node [shape=box style="filled,rounded" fontsize=9 fontname="Arial"
              fontcolor=black margin="0.12,0.08" width=1.0 height=0.5]
        PSU1 [
            label="PSU1\n12 V Netzteil\n(Konstantspannung)"
            shape=cylinder width=1.3 height=1.2
            fillcolor="#FFCCBC" color="#E65100" penwidth=2
            style=filled
        ]
        U2 [
            label="U2: QUARKZMAN\nStep-Down\n12 V → 3,3 V / 3 A"
            shape=box width=2.0 height=1.1
            fillcolor="#FCE4EC" color="#880E4F" penwidth=2
            style="filled,rounded"
        ]
    }

    // ── Cluster: Vorschaltplatine mit TPL5110 ─────────────────────────────────
    //    Außenanschluss: 4 Steckpins (wie am Timer-IC beschriftet)
    //    DELAY wird intern verdrahtet – kein Pin nach außen
    subgraph cluster_vorschalt {
        label="Vorschaltplatine (Streifenrasterplatine)\nmit TPL5110 Power-Timer"
        style=filled fillcolor="#F3E5F5" color="#6A1B9A" penwidth=2
        fontname="Arial" fontsize=11

        // ── 4 Außen-Steckpins ────────────────────────────────────────────────
        node [shape=box style="filled" fillcolor="#ECEFF1" color="#546E7A"
              penwidth=1.6 fontsize=8 fontname="Courier New"
              width=0.62 height=0.32 margin="0.05,0.04"]
        tpl_VDD  [label="VDD"]
        tpl_GND  [label="GND"]
        tpl_DRV  [label="DRV\n(Pin 4)"]
        tpl_DONE [label="DONE\n(Pin 5)"]

        // ── Interne Bauteile ──────────────────────────────────────────────────
        node [shape=box style="filled,rounded" fontsize=9 fontname="Arial"
              fontcolor=black margin="0.12,0.08" width=1.0 height=0.5]
        C2 [
            label="C2\n47–100 µF\nVDD-Puffer"
            width=1.3 height=0.9
            fillcolor="#E1BEE7" color="#6A1B9A"
        ]
        R1 [
            label="R1  47 kΩ\nDELAY → GND\n(6,5 min)"
            width=1.3 height=0.9
            fillcolor="#E1BEE7" color="#6A1B9A"
        ]
        R2 [
            label="R2  10 kΩ\nDONE Pull-down"
            width=1.3 height=0.8
            fillcolor="#E1BEE7" color="#6A1B9A"
        ]
        U1 [
            label="U1 — TPL5110\nPower-Timer IC\nDRV aktiv GND\nim Schlaf → MOSFET AUS"
            shape=box width=2.0 height=1.4
            fillcolor="#CE93D8" color="#6A1B9A" penwidth=2
            style="filled,rounded"
        ]

        gnd_vorschalt
    }

    // ── Cluster: AO3400 Breakoutplatine ──────────────────────────────────────
    //    Außenanschluss ausschließlich über Pin 1, 2, 3
    subgraph cluster_mosfet {
        label="AO3400 Breakoutplatine\n(N-Kanal MOSFET, Low-Side)"
        style=filled fillcolor="#E3F2FD" color="#1565C0" penwidth=2
        fontname="Arial" fontsize=11

        // ── 3 Anschluss-Pins ─────────────────────────────────────────────────
        node [shape=box style="filled" fillcolor="#ECEFF1" color="#546E7A"
              penwidth=1.6 fontsize=8 fontname="Courier New"
              width=0.62 height=0.32 margin="0.05,0.04"]
        q1_p1 [label="Pin 1\n(Gate)"]
        q1_p2 [label="Pin 2\n(Source)"]
        q1_p3 [label="Pin 3\n(Drain)"]

        // ── MOSFET ───────────────────────────────────────────────────────────
        node [shape=box style="filled,rounded" fontsize=9 fontname="Arial"
              fontcolor=black margin="0.12,0.08"]
        Q1 [
            label="Q1 — AO3400\nN-Kanal MOSFET\n(SOT-23)"
            width=1.7 height=1.0
            fillcolor="#BBDEFB" color="#1565C0" penwidth=2
        ]
    }

    // ── Cluster: Recheneinheit & Kamera ──────────────────────────────────────
    //    Außenanschluss: 2 Pins (3,3V und GND geschaltet); C1 intern
    subgraph cluster_mcu {
        label="Recheneinheit & Kamera"
        style=filled fillcolor="#E8F5E9" color="#2E7D32" penwidth=2
        fontname="Arial" fontsize=11

        // ── 2 Außen-Anschlusspins ─────────────────────────────────────────────
        node [shape=box style="filled" fillcolor="#ECEFF1" color="#546E7A"
              penwidth=1.6 fontsize=8 fontname="Courier New"
              width=0.62 height=0.32 margin="0.05,0.04"]
        cam_3V3  [label="3,3 V"]
        cam_GND  [label="GND\n(geschaltet)"]
        cam_DONE [label="GPIO 13\n(DONE)"]

        // ── Interne Bauteile ──────────────────────────────────────────────────
        node [shape=box style="filled,rounded" fontsize=9 fontname="Arial"
              fontcolor=black margin="0.12,0.08"]
        M1 [
            label="M1 — ESP32-CAM\n(AI-Thinker / OV2640)\nBlitz-LED GPIO 4"
            shape=box width=2.2 height=1.1
            fillcolor="#A5D6A7" color="#2E7D32" penwidth=2
            style="filled,rounded"
        ]
        C1 [
            label="C1\n470 µF / 6,3 V\nElko (Low-ESR)"
            shape=box width=1.3 height=0.9
            fillcolor="#C8E6C9" color="#2E7D32"
            style="filled,rounded"
        ]
    }

    // ════════════════════════════════════════════════════════════════════════════
    // KANTEN — Stromversorgung intern: PSU1 → U2 → Ausgangspins
    // ════════════════════════════════════════════════════════════════════════════

    PSU1 -> U2 [
        taillabel="+ (12 V)"  headlabel="VIN"
        color="#E65100" penwidth=2.5 labelfontcolor="#E65100"
        label="12 V"
    ]
    U2 -> psu_3V3 [
        taillabel="VOUT"  headlabel="3,3 V"
        color="#CC7700" penwidth=2.5 labelfontcolor="#CC7700"
    ]
    PSU1 -> psu_GND [
        taillabel="- (GND)"  headlabel=""
        color="#444444" penwidth=1.8 labelfontcolor="#444444"
    ]
    U2 -> psu_GND [
        taillabel="GND"  headlabel=""
        color="#444444" penwidth=1.8 labelfontcolor="#444444"
    ]

    // ════════════════════════════════════════════════════════════════════════════
    // KANTEN — PSU-Pins verteilen an Vorschaltplatine und Kamera
    // ════════════════════════════════════════════════════════════════════════════

    // 3,3 V → Vorschaltplatine VDD-Pin
    psu_3V3 -> tpl_VDD [
        taillabel="3,3 V"  headlabel="VDD"
        color="#CC7700" penwidth=2.5 labelfontcolor="#CC7700"
    ]
    // 3,3 V → Kamera 3,3V-Pin (Dauerpuls, direkt vom PSU)
    psu_3V3 -> cam_3V3 [
        taillabel="3,3 V"  headlabel="3,3 V"
        color="#CC7700" penwidth=2.5 labelfontcolor="#CC7700"
        constraint=false
    ]
    // GND → Vorschaltplatine GND-Pin
    psu_GND -> tpl_GND [
        taillabel="GND"  headlabel="GND"
        color="#444444" penwidth=2.0 labelfontcolor="#444444"
        constraint=false
    ]

    // ════════════════════════════════════════════════════════════════════════════
    // KANTEN — Vorschaltplatine intern
    // ════════════════════════════════════════════════════════════════════════════

    // VDD-Pin: versorgt Timer-IC und Pufferkondensator
    tpl_VDD -> U1 [
        taillabel=""  headlabel="VDD"
        color="#CC7700" penwidth=2.0 labelfontcolor="#CC7700"
    ]
    tpl_VDD -> C2 [
        taillabel=""  headlabel="+"
        color="#CC7700" penwidth=1.8 labelfontcolor="#CC7700"
    ]

    // GND-Pin: versorgt interne GND-Ebene
    tpl_GND -> gnd_vorschalt [
        color="#444444" penwidth=2.0
    ]
    U1 -> gnd_vorschalt [
        taillabel="GND"  headlabel=""
        color="#444444" penwidth=1.8 labelfontcolor="#444444"
    ]
    C2 -> gnd_vorschalt [
        taillabel="-"  headlabel=""
        color="#444444" penwidth=1.5 labelfontcolor="#444444"
    ]
    R1 -> gnd_vorschalt [
        taillabel="Pin 2"  headlabel=""
        color="#444444" penwidth=1.5 labelfontcolor="#444444"
    ]
    R2 -> gnd_vorschalt [
        taillabel="Pin 2"  headlabel=""
        color="#444444" penwidth=1.5 labelfontcolor="#444444"
    ]

    // GND sternförmig: PSU GND-Pin direkt → MOSFET Pin 2 (Source)
    psu_GND -> q1_p2 [
        taillabel="GND"  headlabel="Source"
        color="#444444" penwidth=2.0 labelfontcolor="#444444"
        constraint=false
    ]

    // DELAY: rein intern (kein Außen-Pin)
    U1 -> R1 [
        taillabel="DELAY"  headlabel="Pin 1"
        color="#6A1B9A" penwidth=1.8 labelfontcolor="#6A1B9A"
        label="TPL_DELAY (intern)"
    ]

    // DONE-Pin: R2 Pull-down intern, Eingang von außen (MCU_DONE)
    R2 -> tpl_DONE [
        taillabel="Pin 1"  headlabel=""
        color="#6A1B9A" penwidth=1.5 labelfontcolor="#6A1B9A"
        label="10 kΩ Pull-down"
    ]
    tpl_DONE -> U1 [
        taillabel=""  headlabel="DONE (Pin 5)"
        color="#6A1B9A" penwidth=1.8 labelfontcolor="#6A1B9A"
    ]

    // DRV-Pin: Ausgang des Timers → MOSFET Gate
    U1 -> tpl_DRV [
        taillabel="DRV (Pin 4)"  headlabel=""
        color="#1565C0" penwidth=2.5 labelfontcolor="#1565C0"
        label="TPL_DRV"
    ]
    tpl_DRV -> q1_p1 [
        taillabel="DRV out"  headlabel="Gate"
        color="#1565C0" penwidth=2.5 labelfontcolor="#1565C0"
    ]

    // ════════════════════════════════════════════════════════════════════════════
    // KANTEN — MOSFET-Breakout intern
    // ════════════════════════════════════════════════════════════════════════════

    q1_p1 -> Q1 [
        taillabel=""  headlabel="Gate"
        color="#1565C0" penwidth=2.0 labelfontcolor="#1565C0"
    ]
    q1_p2 -> Q1 [
        taillabel=""  headlabel="Source"
        color="#444444" penwidth=2.0 labelfontcolor="#444444"
    ]
    Q1 -> q1_p3 [
        taillabel="Drain"  headlabel=""
        color="#444444" penwidth=2.0 labelfontcolor="#444444"
    ]

    // ════════════════════════════════════════════════════════════════════════════
    // KANTEN — MOSFET Pin 3 → GND_SWITCHED → Kamera GND-Pin
    // ════════════════════════════════════════════════════════════════════════════

    q1_p3 -> cam_GND [
        taillabel="Drain out"  headlabel="GND"
        color="#444444" penwidth=2.5 labelfontcolor="#444444"
    ]

    // ════════════════════════════════════════════════════════════════════════════
    // KANTEN — Kamera intern: Pins verteilen an M1 und C1
    // ════════════════════════════════════════════════════════════════════════════

    cam_3V3 -> M1 [
        taillabel=""  headlabel="3,3 V"
        color="#CC7700" penwidth=2.0 labelfontcolor="#CC7700"
    ]
    cam_3V3 -> C1 [
        taillabel=""  headlabel="+"
        color="#CC7700" penwidth=1.6 labelfontcolor="#CC7700"
    ]
    cam_GND -> M1 [
        taillabel=""  headlabel="GND"
        color="#444444" penwidth=2.0 labelfontcolor="#444444"
    ]
    cam_GND -> C1 [
        taillabel=""  headlabel="-"
        color="#444444" penwidth=1.6 labelfontcolor="#444444"
    ]

    // ════════════════════════════════════════════════════════════════════════════
    // KANTEN — Feedback: ESP32-CAM GPIO 13 → DONE-Pin (Vorschaltplatine)
    // ════════════════════════════════════════════════════════════════════════════

    M1 -> cam_DONE [
        taillabel="GPIO 13"  headlabel=""
        color="#2E7D32" penwidth=2 labelfontcolor="#2E7D32"
    ]
    cam_DONE -> tpl_DONE [
        taillabel=""  headlabel="DONE"
        color="#2E7D32" penwidth=2 labelfontcolor="#2E7D32"
        label="MCU_DONE" style=dashed
        constraint=false
    ]
}
